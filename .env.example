# Frontend environment variables (Vite)
# Copy to .env.local for local development
# In production, set in Cloudflare Pages Dashboard → Settings → Environment Variables

# Supabase — public anon key (safe for frontend)
VITE_SUPABASE_URL=https://glsmljpabrwonfiltiqm.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps Places API — enables address autocomplete on customer/job/claim forms.
# Must have both "Maps JavaScript API" and "Places API (New)" enabled, and be
# restricted to HTTP referrers (utahpros.com, *.pages.dev, localhost:5173).
# If unset, address inputs fall back to plain text entry (no autocomplete).
VITE_GOOGLE_MAPS_API_KEY=
