{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/scripts/install_pkgs.sh\"",
            "statusMessage": "Installing dependencies (cloud sessions only)..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-secrets.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__Supabase__apply_migration",
      "mcp__Supabase__execute_sql"
    ]
  }
}
