# ─────────────────────────────────────────────────────────────
# Utah Pros Restoration — Demo Sheet Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Then import into Netlify: Site Settings → Environment Variables
# OR run: netlify env:import .env
# ─────────────────────────────────────────────────────────────

# Encircle API Bearer Token (used by Netlify serverless functions)
ENCIRCLE_API_KEY=your-encircle-api-key-here

# Google Maps API Key (embedded in frontend — restrict by domain in Google Console)
# Already hardcoded in demo-sheet-v9.jsx — update there if it changes.
GOOGLE_MAPS_KEY=your-google-maps-api-key-here
